<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<title>TRS - Job Management</title>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<script>
			(() => {
				const key = 'theme-preference';
				const stored = localStorage.getItem(key);
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				const theme = stored ?? (prefersDark ? 'dark' : 'light');
				document.documentElement.classList.toggle('light', theme === 'light');
				document.documentElement.dataset.theme = theme;
			})();
		</script>
		<!--12qhfyh--><meta name="description" content="Job management system for Transducer"/> <meta name="viewport" content="width=device-width, initial-scale=1"/> <link rel="icon" type="image/png" href="/src/lib/assets/ipa_logo.png"/><!----><!--1x05zx6--><!----><title>Login | TRS</title>
